#!/usr/bin/env bash

set -euo pipefail

########################################
# Default values
########################################

prefix="$(pwd)"
ccompiler=""
cflags="-O2"
lflags=""
iflags=""

enable_mpi=auto
enable_openmp=auto

########################################
# OS detection
########################################

OS="$(uname -s)"

echo "Detected OS: $OS"

########################################
# Argument parsing
########################################

for arg in "$@"; do
    case "$arg" in
        --prefix=*) prefix="${arg#*=}" ;;
        --ccompiler=*) ccompiler="${arg#*=}" ;;
        --enable-mpi) enable_mpi=yes ;;
        --disable-mpi) enable_mpi=no ;;
        --debug) cflags="-g -O1 -Wall -Wshadow -Wextra -Warray-bounds -pedantic" ;;
        --hard) cflags="-O3" ;;
        --help)
            echo "Usage: ./configure [options]"
            exit 0 ;;
        *)
            echo "Unknown option: $arg"
            exit 1 ;;
    esac
done

########################################
# Compiler selection
########################################

if [ -z "$ccompiler" ]; then
    if command -v mpicc >/dev/null 2>&1; then
        ccompiler="mpicc"
    elif command -v gcc >/dev/null 2>&1; then
        ccompiler="gcc"
    elif command -v clang >/dev/null 2>&1; then
        ccompiler="clang"
    else
        echo "ERROR: No C compiler found."
        exit 1
    fi
fi

echo "Using compiler: $ccompiler"


########################################
# CFITSIO detection
########################################

echo "Checking CFITSIO..."

if pkg-config --exists cfitsio 2>/dev/null; then
    echo "CFITSIO found via pkg-config"
    iflags="$(pkg-config --cflags cfitsio)"
    lflags="$lflags $(pkg-config --libs cfitsio)"

else
    # macOS Homebrew
    if [ "$OS" = "Darwin" ] && brew --prefix cfitsio >/dev/null 2>&1; then
        CFITSIO_PREFIX=$(brew --prefix cfitsio)
        echo "Using Homebrew CFITSIO"
        iflags="-I$CFITSIO_PREFIX/include"
        lflags="$lflags -L$CFITSIO_PREFIX/lib -lcfitsio"

    else
        echo "Trying manual link test..."
        tmpfile=$(mktemp "${TMPDIR:-/tmp}/conftestXXXXXX.c")

        cat << EOF > "$tmpfile"
#include <fitsio.h>
int main(){ return 0; }
EOF

        if "$ccompiler" "$tmpfile" -lcfitsio -o /dev/null >/dev/null 2>&1; then
            echo "CFITSIO found via -lcfitsio"
            lflags="$lflags -lcfitsio"
        else
            echo "ERROR: CFITSIO not found."
            exit 1
        fi

        rm -f "$tmpfile"
    fi
fi

########################################
# Ensure prefix trailing slash
########################################

case "$prefix" in
    */) ;;
    *) prefix="$prefix/";;
esac

########################################
# Generate Makefile
########################################

echo "Generating Makefile..."

tmpfile=$(mktemp)

{
    echo "PREFIX = $prefix"
    echo "CMP = $ccompiler"
    echo "CFLAGS = -c $cflags "
    echo "LFLAGS = $lflags"
    echo "IFLAGS = $iflags"
    cat Src/makefile.in
} > "$tmpfile"

mv "$tmpfile" Makefile

echo ""
echo "Configuration summary:"
echo "  OS:        $OS"
echo "  Compiler:  $ccompiler"
echo "  MPI:       auto"
echo "  CFITSIO:   detected"
echo ""
echo "Run 'make' to build."