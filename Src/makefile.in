#*--------------------------------------------------------------------------------*#
# Directory structure
#*--------------------------------------------------------------------------------*#

src_dir := Src
obj_dir := Objs
bin_dir := .

TARGET  := MEINV

#*--------------------------------------------------------------------------------*#
# Automatically detect sources
#*--------------------------------------------------------------------------------*#

SRC  := $(wildcard $(src_dir)/*.c)
OBJS := $(patsubst $(src_dir)/%.c,$(obj_dir)/%.o,$(SRC))
DEPS := $(OBJS:.o=.d)

#*--------------------------------------------------------------------------------*#
# Default target
#*--------------------------------------------------------------------------------*#

all: $(TARGET)

#*--------------------------------------------------------------------------------*#
# Build rules
#*--------------------------------------------------------------------------------*#

# Ensure object directory exists
$(obj_dir):
	mkdir -p $(obj_dir)

# Compile with dependency generation
$(obj_dir)/%.o: $(src_dir)/%.c | $(obj_dir)
	$(CMP) $(CFLAGS) -MMD -MP -o $@ $< $(IFLAGS)

#*--------------------------------------------------------------------------------*#
# Link
#*--------------------------------------------------------------------------------*#

$(TARGET): $(OBJS)
	$(CMP) -o $@ $(OBJS) $(LFLAGS) -lm

#*--------------------------------------------------------------------------------*#
# Install
#*--------------------------------------------------------------------------------*#

install: $(TARGET)
	mkdir -p $(PREFIX)/bin
	cp $(TARGET) $(PREFIX)/bin/

#*--------------------------------------------------------------------------------*#
# Clean
#*--------------------------------------------------------------------------------*#

clean:
	rm -rf $(obj_dir)/*.o $(obj_dir)/*.d $(TARGET)

#*--------------------------------------------------------------------------------*#
# Include dependency files
#*--------------------------------------------------------------------------------*#

-include $(DEPS)

#*--------------------------------------------------------------------------------*#
# Phony targets
#*--------------------------------------------------------------------------------*#

.PHONY: all clean install